; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Aware"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameEvents="*res://autoloads/game_events.gd"
RunManager="*res://autoloads/run_manager.gd"
SettingsManager="*res://autoloads/settings_manager.gd"
MetaProgression="*res://autoloads/meta_progression.gd"
AudioManager="*res://autoloads/audio_manager.gd"
ToonApplicator="*res://autoloads/toon_applicator.gd"
CharacterApplicator="*res://autoloads/character_applicator.gd"
DeletionVFX="*res://autoloads/deletion_vfx.gd"
WeaponClip="*res://autoloads/weapon_clip.gd"
BulletFX="*res://autoloads/bullet_fx.gd"
FragmentDB="*res://autoloads/fragment_db.gd"
DevTools="*res://autoloads/dev_tools.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900

